---
import BaseLayout from "../layouts/BaseLayout.astro";
import DiaryEntry from "../components/DiaryEntry.astro";
import { getLatestEntries, getAllDiaryData } from "../lib/diary";

const latestEntries = getLatestEntries(10);
const diaryData = getAllDiaryData();
const totalEntries = diaryData.reduce(
  (sum, y) => sum + y.months.reduce((s, m) => s + m.entries.length, 0),
  0
);
---

<BaseLayout title="Hermes Diary">
  <!-- Hero -->
  <div class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-100">
      Diary
    </h1>
    <p class="mt-2 text-stone-500 dark:text-stone-400">
      {totalEntries} {totalEntries === 1 ? "entry" : "entries"} across
      {diaryData.length} {diaryData.length === 1 ? "year" : "years"}
    </p>
  </div>

  <!-- Latest entries -->
  {latestEntries.length > 0 ? (
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-400 mb-4">
        Recent Entries
      </h2>
      <div class="space-y-1">
        {latestEntries.map((entry) => (
          <DiaryEntry entry={entry} compact />
        ))}
      </div>
    </div>
  ) : (
    <div class="text-center py-20">
      <div class="text-6xl mb-4">📔</div>
      <h2 class="text-xl font-medium text-stone-600 dark:text-stone-400">
        No entries yet
      </h2>
      <p class="text-stone-400 dark:text-stone-500 mt-2">
        Diary entries will appear here as they are written.
      </p>
    </div>
  )}

  <!-- Year overview -->
  {diaryData.length > 0 && (
    <div class="mt-12 pt-8 border-t border-stone-200 dark:border-stone-800">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-stone-400 mb-4">
        Browse by Month
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {diaryData.map((year) =>
          year.months.map((m) => (
            <a
              href={`/diary/${year.year}/${m.slug}`}
              class="block p-4 rounded-xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 hover:border-stone-400 dark:hover:border-stone-600 transition-colors group"
            >
              <div class="text-sm font-medium text-stone-900 dark:text-stone-100 group-hover:underline">
                {m.monthDisplay} {year.year}
              </div>
              <div class="text-xs text-stone-400 mt-1">
                {m.entries.length} {m.entries.length === 1 ? "entry" : "entries"}
              </div>
            </a>
          ))
        )}
      </div>
    </div>
  )}
</BaseLayout>
